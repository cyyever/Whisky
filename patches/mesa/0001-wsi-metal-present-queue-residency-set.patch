diff --git a/src/kosmickrisp/vulkan/kk_queue.c b/src/kosmickrisp/vulkan/kk_queue.c
index 313a85af8a08..12341e2b444b 100644
--- a/src/kosmickrisp/vulkan/kk_queue.c
+++ b/src/kosmickrisp/vulkan/kk_queue.c
@@ -81,6 +81,11 @@ kk_queue_submit(struct vk_queue *vk_queue, struct vk_queue_submit *submit)
       uint32_t count = util_dynarray_num_elements(&cmd_buffer->submit_cmd_bufs,
