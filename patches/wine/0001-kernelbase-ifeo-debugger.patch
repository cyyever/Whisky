+    /* Honour a launcher configured in the image's Image File Execution Options
+     * "Debugger" value: prepend it to the command line and run it instead. This
+     * lets a wrapper inject extra arguments without modifying the target binary.
+     * Skipped when the caller is starting its own debuggee. */
+    if (!(flags & (DEBUG_PROCESS | DEBUG_ONLY_THIS_PROCESS)))
+    {
+        WCHAR *debugger = get_image_file_debugger( app_name );
+
+        if (debugger)
+        {
+            SIZE_T len = lstrlenW( debugger ) + lstrlenW( tidy_cmdline ) + 2;
+            WCHAR *combined = RtlAllocateHeap( GetProcessHeap(), 0, len * sizeof(WCHAR) );
+
+            if (combined)
+            {
+                WCHAR *resolved;
+
+                swprintf( combined, len, L"%s %s", debugger, tidy_cmdline );
+                if ((resolved = get_file_name( combined, name, ARRAY_SIZE(name) )))
+                {
+                    TRACE( "IFEO debugger %s wrapping %s\n",
+                           debugstr_w(debugger), debugstr_w(app_name) );
+                    if (tidy_cmdline != cmd_line) RtlFreeHeap( GetProcessHeap(), 0, tidy_cmdline );
+                    if (resolved != combined) RtlFreeHeap( GetProcessHeap(), 0, combined );
+                    tidy_cmdline = resolved;
+                    app_name = name;
+                }
+                else RtlFreeHeap( GetProcessHeap(), 0, combined );
+            }
+            RtlFreeHeap( GetProcessHeap(), 0, debugger );
+        }
+    }
+
