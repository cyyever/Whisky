+/***********************************************************************
+ *           get_image_file_debugger
+ *
+ * Return the "Debugger" string configured in the Image File Execution
+ * Options for the given image (matched by leaf name), or NULL if none.
+ * Used to wrap a process with a launcher at creation time. Caller frees.
+ */
+static WCHAR *get_image_file_debugger( const WCHAR *image )
+{
+    UNICODE_STRING image_str;
+    WCHAR *buffer;
+    ULONG size = 0;
+
+    if (!image) return NULL;
+    RtlInitUnicodeString( &image_str, image );
+    if (LdrQueryImageFileExecutionOptions( &image_str, L"Debugger", REG_SZ,
+                                           NULL, 0, &size ) != STATUS_BUFFER_TOO_SMALL || !size)
+        return NULL;
+    if (!(buffer = RtlAllocateHeap( GetProcessHeap(), 0, size + sizeof(WCHAR) ))) return NULL;
+    if (LdrQueryImageFileExecutionOptions( &image_str, L"Debugger", REG_SZ, buffer, size, &size ))
+    {
+        RtlFreeHeap( GetProcessHeap(), 0, buffer );
+        return NULL;
+    }
+    buffer[size / sizeof(WCHAR)] = 0;
+    if (!buffer[0])
+    {
+        RtlFreeHeap( GetProcessHeap(), 0, buffer );
+        return NULL;
+    }
+    return buffer;
+}
+
 /**********************************************************************
  *           CreateProcessInternalW   (kernelbase.@)
