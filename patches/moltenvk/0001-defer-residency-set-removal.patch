From ff69cf18f86fe1d7e4c9bf8652b216050282a93f Mon Sep 17 00:00:00 2001
From: Yuanyuan Chen <cyyever@outlook.com>
Date: Fri, 3 Jul 2026 17:50:54 +0800
Subject: [PATCH] Defer residency set removal until referencing command buffers
 complete

Removing an allocation the instant the app destroys the resource can free it
while a completed-but-not-yet-released command buffer (retainedReferences = NO)
still references it, aborting Metal as VK_ERROR_DEVICE_LOST. Defer removal until
a later submission completes, or waitIdle. Repro'd with DXVK (D3D9) on macOS.

Signed-off-by: Yuanyuan Chen <cyyever@outlook.com>
---
 MoltenVK/MoltenVK/GPUObjects/MVKDevice.h | 54 +++++++++++++++++++++++-
 MoltenVK/MoltenVK/GPUObjects/MVKQueue.mm |  5 +++
 2 files changed, 58 insertions(+), 1 deletion(-)

diff --git a/MoltenVK/MoltenVK/GPUObjects/MVKDevice.h b/MoltenVK/MoltenVK/GPUObjects/MVKDevice.h
index 1b4851a..391c965 100644
--- a/MoltenVK/MoltenVK/GPUObjects/MVKDevice.h
+++ b/MoltenVK/MoltenVK/GPUObjects/MVKDevice.h
@@ -986,10 +986,59 @@ public:
 
 #if !MVK_XCODE_16
 	void removeResidency(id allocation) {}
+	void drainDeferredResidencyRemovals() {}
+	void flushDeferredResidencyRemovals() {}
 #else
+	// A residency set retains the allocations added to it, and on the residency-set submission path
+	// command buffers are created with retainedReferences = NO. That residency-set retain can therefore
+	// be the last thing keeping a resource alive while a completed-but-not-yet-released MTLCommandBuffer
+	// still references it. Removing the allocation the instant the app destroys the resource drops that
+	// retain inside the window before Metal releases the command buffer, and Metal aborts on the dangling
+	// reference (surfacing as VK_ERROR_DEVICE_LOST). Instead of removing immediately, defer the removal
+	// until a later queue submission has completed; the resource stays in the residency set, and thus
+	// alive, until then.
 	void removeResidency(id<MTLAllocation> allocation) {
+		if ( !_residencySet || !allocation ) { return; }
+		std::lock_guard<std::mutex> lock(_deferredResidencyLock);
+		_deferredResidencyRemovals.push_back(allocation);
+	}
+
+	// Called when a queue submission completes: the allocations that were pending as of the previous
+	// completion can now be removed, because any command buffer that referenced them has been released.
+	// Ping-ponging the two lists guarantees each allocation survives at least one full submit/complete
+	// cycle after the app destroyed it.
+	void drainDeferredResidencyRemovals() {
+		if ( !_residencySet ) { return; }
+		MVKSmallVector<id<MTLAllocation>> draining;
+		{
+			std::lock_guard<std::mutex> lock(_deferredResidencyLock);
+			if (_drainingResidencyRemovals.empty() && _deferredResidencyRemovals.empty()) { return; }
+			draining = std::move(_drainingResidencyRemovals);
+			_drainingResidencyRemovals = std::move(_deferredResidencyRemovals);
+			_deferredResidencyRemovals.clear();
+		}
+		removeResidencyAllocations(draining);
+	}
+
+	// Called when the GPU is known to be idle (queue/device waitIdle): everything can be removed now.
+	void flushDeferredResidencyRemovals() {
+		if ( !_residencySet ) { return; }
+		MVKSmallVector<id<MTLAllocation>> draining, deferred;
+		{
+			std::lock_guard<std::mutex> lock(_deferredResidencyLock);
+			draining = std::move(_drainingResidencyRemovals);
+			deferred = std::move(_deferredResidencyRemovals);
+			_drainingResidencyRemovals.clear();
+			_deferredResidencyRemovals.clear();
+		}
+		removeResidencyAllocations(draining);
+		removeResidencyAllocations(deferred);
+	}
+
+	void removeResidencyAllocations(MVKSmallVector<id<MTLAllocation>>& allocations) {
+		if (allocations.empty()) { return; }
 		@synchronized(_residencySet) {
-			[_residencySet removeAllocation:allocation];
+			for (id<MTLAllocation> allocation : allocations) { [_residencySet removeAllocation: allocation]; }
 			[_residencySet commit];
 		}
 	}
@@ -1109,6 +1158,9 @@ protected:
 	id<MTLBuffer> _dummyBlitMTLBuffer = nil;
 #if MVK_XCODE_16
 	id<MTLResidencySet> _residencySet = nil;
+	MVKSmallVector<id<MTLAllocation>> _deferredResidencyRemovals;	// destroyed resources awaiting removal from _residencySet
+	MVKSmallVector<id<MTLAllocation>> _drainingResidencyRemovals;	// removals promoted from _deferredResidencyRemovals, removed on the next completion
+	std::mutex _deferredResidencyLock;
 #endif
 	uint32_t _visibilityBufferCount = 0;
 	int _capturePipeFileDesc = -1;
diff --git a/MoltenVK/MoltenVK/GPUObjects/MVKQueue.mm b/MoltenVK/MoltenVK/GPUObjects/MVKQueue.mm
index dec4b45..281dbb1 100644
--- a/MoltenVK/MoltenVK/GPUObjects/MVKQueue.mm
+++ b/MoltenVK/MoltenVK/GPUObjects/MVKQueue.mm
@@ -160,6 +160,8 @@ VkResult MVKQueue::waitIdle(MVKCommandUse cmdUse) {
 		[mtlCmdBuff commit];
 		[mtlCmdBuff waitUntilCompleted];
 	}
+	// The GPU is idle, so any resources destroyed while work was outstanding can be removed now.
+	_device->flushDeferredResidencyRemovals();
 	return _device->getConfigurationResult();
 }
 
@@ -548,6 +550,9 @@ VkResult MVKQueueCommandBufferSubmission::commitActiveMTLCommandBuffer(bool sign
 	uint64_t startTime = getPerformanceTimestamp();
 	[mtlCmdBuff addCompletedHandler: ^(id<MTLCommandBuffer> mtlCB) {
 		addPerformanceInterval(getPerformanceStats().queue.mtlCommandBufferExecution, startTime);
+		// A command buffer has completed and been released, so it is now safe to remove from the
+		// residency set the resources that were destroyed while it was in flight.
+		getDevice()->drainDeferredResidencyRemovals();
 		if (signalCompletion) { this->finish(); }	// Must be the last thing the completetion callback does.
 	}];
 
-- 
2.55.0

