+static void test_IFEO_debugger(void)
+{
+    char tmp_path[MAX_PATH], child[MAX_PATH];
+    static const char child_name[] = "winetest_ifeo_child.exe";
+    char key_name[MAX_PATH], debugger[2 * MAX_PATH], cmdline[2 * MAX_PATH], buffer[MAX_PATH], *file_part;
+    PROCESS_INFORMATION info;
+    STARTUPINFOA startup;
+    DWORD count;
+    HKEY key;
+    LONG res;
+    BOOL ret;
+
+    /* A private copy of the test binary under a distinct name, so the IFEO entry
+     * only affects this test and not the test's own child invocations. */
+    GetTempPathA(sizeof(tmp_path), tmp_path);
+    sprintf(child, "%s%s", tmp_path, child_name);
+    ret = CopyFileA(selfname, child, FALSE);
+    ok(ret, "failed to copy %s, error %lu\n", selfname, GetLastError());
+    if (!ret) return;
+
+    sprintf(key_name, "Software\\Microsoft\\Windows NT\\CurrentVersion\\Image File Execution Options\\%s",
+            child_name);
+    res = RegCreateKeyExA(HKEY_LOCAL_MACHINE, key_name, 0, NULL, 0, KEY_SET_VALUE, NULL, &key, NULL);
+    if (res == ERROR_ACCESS_DENIED)
+    {
+        skip("not enough privileges to set Image File Execution Options\n");
+        DeleteFileA(child);
+        return;
+    }
+    ok(!res, "failed to create IFEO key, error %ld\n", res);
+
+    get_file_name(resfile);
+    sprintf(debugger, "\"%s\" process debugger \"%s\"", selfname, resfile);
+    res = RegSetValueExA(key, "Debugger", 0, REG_SZ, (const BYTE *)debugger, strlen(debugger) + 1);
+    ok(!res, "failed to set Debugger value, error %ld\n", res);
+
+    /* Launching the child should instead run the debugger, with the child's
+     * image and arguments appended to the debugger command line. */
+    memset(&startup, 0, sizeof(startup));
+    startup.cb = sizeof(startup);
+    sprintf(cmdline, "\"%s\" process exit", child);
+    ret = CreateProcessA(child, cmdline, NULL, NULL, FALSE, 0, NULL, NULL, &startup, &info);
+    ok(ret, "CreateProcess failed, error %lu\n", GetLastError());
+    if (ret)
+    {
+        WaitForSingleObject(info.hProcess, 10000);
+        CloseHandle(info.hThread);
+        CloseHandle(info.hProcess);
+
+        reload_child_info(resfile);
+        count = GetPrivateProfileIntA("debugger", "argc", 0, resfile);
+        ok(count >= 1, "debugger was not invoked (argc %lu)\n", count);
+
+        buffer[0] = 0;
+        GetPrivateProfileStringA("debugger", "arg0", "", buffer, sizeof(buffer), resfile);
+        file_part = strrchr(buffer, '\\');
+        file_part = file_part ? file_part + 1 : buffer;
+        ok(!lstrcmpiA(file_part, child_name),
+           "debugger received image %s, expected %s\n", buffer, child_name);
+    }
+
+    DeleteFileA(resfile);
+    RegDeleteValueA(key, "Debugger");
+    RegCloseKey(key);
+    RegDeleteKeyA(HKEY_LOCAL_MACHINE, key_name);
+    DeleteFileA(child);
+}
+
