+++ b/server/object.c
@@ -37,6 +37,7 @@
 #include "winternl.h"
 
 #include "file.h"
+#include "msync.h"
 #include "process.h"
 #include "thread.h"
 #include "unicode.h"
@@ -313,6 +314,7 @@ void *alloc_object( const struct object_ops *ops )
         obj->ops          = ops;
