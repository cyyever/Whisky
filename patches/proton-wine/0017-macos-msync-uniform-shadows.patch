From: cyy <cyyever@gmail.com>
Date: Tue, 22 Jul 2026 00:00:00 +0000
Subject: [PATCH] macos/msync: uniform inproc_sync shadows + honor WINEMSYNC

Build on the msync fast-sync (0008) and the mixed-wait hybrid (0014) with the
architectural fix those were working around: give EVERY waitable object a
server-side fast-sync shadow so waits never have to mix fast msync objects with
pure-server objects in the first place.

- server/inproc_sync.c: implement the macOS (non-ntsync) inproc_sync backend,
  which 0008 left stubbed (create_* returned NULL, get_inproc_sync_fd returned
  -1). Each inproc_sync now owns an msync shm slot; signal/reset/destroy map to
  msync_signal_all / msync_clear_shm / msync_destroy_semaphore. A shadow is its
  own sync (inproc_self_get_sync) so default_get_sync never shadows a shadow.

- server/object.c, object.h: add a lazily-created struct object.sync shadow.
  default_get_sync() now, under msync, creates an msync-backed inproc_sync that
  mirrors the object's signaled state, released in free_object(). Process /
  Thread / Msg-queue / etc. thus get a fast shadow, so a WaitForMultipleObjects
  mixing them with an event stays entirely on the msync fast path instead of
  flooding the wineserver with poll waits (which stalls badly under Rosetta).

- server/msync.c: route msync_wake_up / msync_clear / get_msync_idx through the
  generic get_obj_inproc_sync() so they follow the object's shadow. Also route
  mach_msg2() through libSystem's public mach_msg() -- the dlsym'd raw
  mach_msg2_trap is called through an untranslated pointer and crashes under
  Rosetta.

- dlls/ntdll/unix/sync.c, server/inproc_sync.c: pass the inproc-sync fd as an
  shm index by value on macOS (fsync_shm_idx reply field) rather than via
  send_client_fd / wine_server_receive_fd -- an msync slot is not a real fd.

- dlls/ntdll/unix/sync.c: restore the do_msync() dispatch guards on
  NtResetEvent / NtPulseEvent and add one to NtWaitForSingleObject. Without them
  the client falls through to the server event_op path against an msync-backed
  object and wineserver asserts (event->sync mis-typed) -- the boot crash.

- dlls/ntdll/unix/msync.c: do_msync() honors WINEMSYNC (was hardcoded on) so it
  can be toggled off for debugging; matches the server-side do_msync in 0008's
  server/msync.c. Add a negative cache so a NOT_IMPLEMENTED (server-only) handle
  is looked up once, and a once-per-process >5s stall log in the mixed-wait poll
  as a lost-wakeup debug aid.
diff --git a/dlls/ntdll/unix/msync.c b/dlls/ntdll/unix/msync.c
index 9579cb3..cecf663 100644
--- a/dlls/ntdll/unix/msync.c
+++ b/dlls/ntdll/unix/msync.c
@@ -548,9 +548,15 @@ static NTSTATUS msync_wait_multiple( struct msync **wait_objs,
 int do_msync(void)
 {
 #ifdef __APPLE__
-    /* msync (__ulock) is the only working fast-sync on macOS -- the wineserver
-     * fallback is unreliable -- so it is always enabled here. */
-    return 1;
+    /* msync (__ulock) is the default fast-sync on macOS; the wineserver fallback
+     * is slower/less reliable, so default on. WINEMSYNC=0 forces it off (debug). */
+    static int cached = -1;
+    if (cached == -1)
+    {
+        const char *env = getenv( "WINEMSYNC" );
+        cached = env ? atoi( env ) : 1;
+    }
+    return cached;
 #else
     static int once;
     if (!once++)
@@ -628,6 +634,14 @@ static void *get_shm( unsigned int idx )
 /* We'd like lookup to be fast. To that end, we use a static list indexed by handle.
  * This is copied and adapted from the fd cache code. */
 
+/* Not a real msync_type: a sentinel cached for handles the server reported as
+ * having no msync shadow (server-only objects: pipes, sockets, processes, ...).
+ * It lets get_object() skip the get_msync_idx round-trip on repeated waits --
+ * without it, polling a mixed wait-set (e.g. Steam's IPC pipes) issues one
+ * server round-trip per handle per poll, starving the reader. Cleared by
+ * msync_close() on handle close like any entry, so handle reuse stays correct. */
+#define MSYNC_SERVER_ONLY ((enum msync_type)0xff)
+
 #define MSYNC_LIST_BLOCK_SIZE  (65536 / sizeof(struct msync))
 #define MSYNC_LIST_ENTRIES     256
 
@@ -644,7 +658,7 @@ static inline UINT_PTR handle_to_index( HANDLE handle, UINT_PTR *entry )
 static struct msync *add_to_list( HANDLE handle, enum msync_type type, unsigned int shm_idx )
 {
     UINT_PTR entry, idx = handle_to_index( handle, &entry );
-    void *shm = get_shm( shm_idx );
+    void *shm = (type == MSYNC_SERVER_ONLY) ? NULL : get_shm( shm_idx );
 
     if (entry >= MSYNC_LIST_ENTRIES)
     {
@@ -693,7 +707,11 @@ static NTSTATUS get_object( HANDLE handle, struct msync **obj )
     unsigned int shm_idx = 0;
     enum msync_type type;
 
-    if ((*obj = get_cached_object( handle ))) return STATUS_SUCCESS;
+    if ((*obj = get_cached_object( handle )))
+    {
+        if ((*obj)->type == MSYNC_SERVER_ONLY) { *obj = NULL; return STATUS_NOT_IMPLEMENTED; }
+        return STATUS_SUCCESS;
+    }
 
     if ((INT_PTR)handle < 0)
     {
@@ -715,7 +733,12 @@ static NTSTATUS get_object( HANDLE handle, struct msync **obj )
 
     if (ret)
     {
-        WARN("Failed to retrieve shm index for handle %p, status %#x.\n", handle, ret);
+        /* A server-only object (no msync shadow): remember it so future waits
+         * don't re-query the server for the same handle. */
+        if (ret == STATUS_NOT_IMPLEMENTED)
+            add_to_list( handle, MSYNC_SERVER_ONLY, 0 );
+        else
+            WARN("Failed to retrieve shm index for handle %p, status %#x.\n", handle, ret);
         *obj = NULL;
         return ret;
     }
@@ -1192,6 +1215,7 @@ static NTSTATUS msync_wait_mixed_any( DWORD count, const HANDLE *handles,
     unsigned int server_count = 0, flags, i;
     int current_tid = GetCurrentThreadId();
     LONGLONG interval = MSYNC_MIXED_POLL_INTERVAL;
+    LARGE_INTEGER diag_start = {0};
     NTSTATUS ret;
 
     flags = SELECT_INTERRUPTIBLE | (alertable ? SELECT_ALERTABLE : 0);
@@ -1294,6 +1318,33 @@ static NTSTATUS msync_wait_mixed_any( DWORD count, const HANDLE *handles,
         /* Only a poll timeout means "recheck"; propagate any real error. */
         if (ret != STATUS_TIMEOUT) return ret;
 
+        /* Diagnostic: flag a single mixed wait that never wakes (a lost wakeup,
+         * as opposed to legitimately blocking) -- logged once per process. This
+         * is cheap (the poll already backs off) and is the only place a stuck
+         * msync+server wait would show up, so keep it as a debug aid. */
+        if (!diag_start.QuadPart)
+            NtQuerySystemTime( &diag_start );
+        else
+        {
+            LARGE_INTEGER now2;
+            NtQuerySystemTime( &now2 );
+            if (now2.QuadPart - diag_start.QuadPart > 50000000 /* 5s */)
+            {
+                static int stall_logged;
+                if (!stall_logged) { stall_logged = 1;
+                    ERR("mixed wait looping >5s (possible lost wakeup): count=%u server_count=%u\n",
+                        count, server_count);
+                    for (i = 0; i < count; i++)
+                    {
+                        if (!objs[i])
+                            ERR("  [%u] SERVER handle=%p\n", i, handles[i]);
+                        else
+                            ERR("  [%u] msync type=%d signaled=%d handle=%p\n", i, objs[i]->type,
+                                __atomic_load_n( (int *)objs[i]->shm, __ATOMIC_SEQ_CST ), handles[i]);
+                    } }
+            }
+        }
+
         /* Back off so an idle mixed wait doesn't busy-poll the server forever. */
         if (interval < MSYNC_MIXED_POLL_MAX) interval *= 2;
     }
diff --git a/dlls/ntdll/unix/sync.c b/dlls/ntdll/unix/sync.c
index 4aac92d..bbbfde8 100644
--- a/dlls/ntdll/unix/sync.c
+++ b/dlls/ntdll/unix/sync.c
@@ -678,10 +678,15 @@ static NTSTATUS get_server_inproc_sync( HANDLE handle, struct inproc_sync *sync
         req->handle = wine_server_obj_handle( handle );
         if (!(ret = wine_server_call( req )))
         {
-            obj_handle_t fd_handle;
             sync->refcount = 1;
-            sync->fd = wine_server_receive_fd( &fd_handle );
-            assert( wine_server_ptr_handle(fd_handle) == handle );
+            if (do_msync())
+                sync->fd = reply->fsync_shm_idx; /* macOS: msync shm index, passed by value */
+            else
+            {
+                obj_handle_t fd_handle;
+                sync->fd = wine_server_receive_fd( &fd_handle );
+                assert( wine_server_ptr_handle(fd_handle) == handle );
+            }
             sync->access = reply->access;
             sync->type = reply->type;
             sync->closed = 0;
@@ -1214,13 +1219,6 @@ NTSTATUS WINAPI NtSetEvent( HANDLE handle, LONG *prev_state )
     if (do_msync())
         return msync_set_event( handle, prev_state );
 
-    if (do_msync())
-        return msync_reset_event( handle, prev_state );
-
-
-    if (do_msync())
-        return msync_pulse_event( handle, prev_state );
-
     SERVER_START_REQ( event_op )
     {
         req->handle = wine_server_obj_handle( handle );
@@ -1254,6 +1252,9 @@ NTSTATUS WINAPI NtResetEvent( HANDLE handle, LONG *prev_state )
     if ((ret = inproc_reset_event( handle, prev_state )) != STATUS_NOT_IMPLEMENTED)
         return ret;
 
+    if (do_msync())
+        return msync_reset_event( handle, prev_state );
+
     SERVER_START_REQ( event_op )
     {
         req->handle = wine_server_obj_handle( handle );
@@ -1288,6 +1289,9 @@ NTSTATUS WINAPI NtPulseEvent( HANDLE handle, LONG *prev_state )
     if ((ret = inproc_pulse_event( handle, prev_state )) != STATUS_NOT_IMPLEMENTED)
         return ret;
 
+    if (do_msync())
+        return msync_pulse_event( handle, prev_state );
+
     SERVER_START_REQ( event_op )
     {
         req->handle = wine_server_obj_handle( handle );
@@ -2443,6 +2447,16 @@ NTSTATUS WINAPI NtWaitForSingleObject( HANDLE handle, BOOLEAN alertable, const L
         return ret;
     }
 
+    if (do_msync())
+    {
+        ret = msync_wait_objects( 1, &handle, TRUE, alertable, timeout );
+        if (ret != STATUS_NOT_IMPLEMENTED)
+        {
+            TRACE( "-> %#x\n", ret );
+            return ret;
+        }
+    }
+
     if (alertable) flags |= SELECT_ALERTABLE;
     select_op.wait.op = SELECT_WAIT;
     select_op.wait.handles[0] = wine_server_obj_handle( handle );
diff --git a/server/inproc_sync.c b/server/inproc_sync.c
index 0624e83..81e2c6c 100644
--- a/server/inproc_sync.c
+++ b/server/inproc_sync.c
@@ -35,11 +35,29 @@
 #include "user.h"
 
 #include "fsync.h"
+#include "msync.h"
 
 #ifdef __linux__
 #include "ntsync_tmp.h"
 #endif
 
+struct inproc_sync
+{
+    struct object          obj;  /* object header */
+    enum inproc_sync_type  type;
+    int                    fd;
+    struct list            entry;
+};
+
+static struct list inproc_mutexes = LIST_INIT( inproc_mutexes );
+
+/* a shadow is its own sync: return it directly so default_get_sync never tries
+ * to shadow a shadow (which would recurse). */
+static struct object *inproc_self_get_sync( struct object *obj )
+{
+    return grab_object( obj );
+}
+
 #ifdef NTSYNC_IOC_EVENT_READ
 
 #include <fcntl.h>
@@ -67,16 +85,6 @@ int get_inproc_device_fd(void)
     return fd;
 }
 
-struct inproc_sync
-{
-    struct object          obj;  /* object header */
-    enum inproc_sync_type  type;
-    int                    fd;
-    struct list            entry;
-};
-
-static struct list inproc_mutexes = LIST_INIT( inproc_mutexes );
-
 static void inproc_sync_dump( struct object *obj, int verbose );
 static int inproc_sync_signal( struct object *obj, unsigned int access, int signal );
 static void inproc_sync_destroy( struct object *obj );
@@ -93,7 +101,7 @@ static const struct object_ops inproc_sync_ops =
     NULL,                       /* satisfied */
     inproc_sync_signal,         /* signal */
     no_get_fd,                  /* get_fd */
-    default_get_sync,           /* get_sync */
+    inproc_self_get_sync,       /* get_sync */
     default_map_access,         /* map_access */
     default_get_sd,             /* get_sd */
     default_set_sd,             /* set_sd */
@@ -283,7 +291,7 @@ void abandon_inproc_mutexes( thread_id_t tid )
         ioctl( mutex->fd, NTSYNC_IOC_MUTEX_KILL, &tid );
 }
 
-static int get_obj_inproc_sync( struct object *obj, int *type )
+int get_obj_inproc_sync( struct object *obj, int *type )
 {
     struct object *sync;
     int fd = -1;
@@ -302,6 +310,41 @@ static int get_obj_inproc_sync( struct object *obj, int *type )
 
 #else /* NTSYNC_IOC_EVENT_READ */
 
+/* macOS / non-ntsync platforms: back inproc_sync with msync (__ulock shared
+ * memory). sync->fd holds the msync shm index. This is the native fast-sync
+ * path -- without it every object's ->sync is NULL and all waits fall back to
+ * (hanging) server-side sync. */
+
+static void inproc_sync_dump( struct object *obj, int verbose );
+static int inproc_sync_signal( struct object *obj, unsigned int access, int signal );
+static void inproc_sync_destroy( struct object *obj );
+
+static const struct object_ops inproc_sync_ops =
+{
+    sizeof(struct inproc_sync), /* size */
+    &no_type,                   /* type */
+    inproc_sync_dump,           /* dump */
+    no_add_queue,               /* add_queue */
+    NULL,                       /* remove_queue */
+    NULL,                       /* signaled */
+    NULL,                       /* get_msync_idx */
+    NULL,                       /* satisfied */
+    inproc_sync_signal,         /* signal */
+    no_get_fd,                  /* get_fd */
+    inproc_self_get_sync,       /* get_sync */
+    default_map_access,         /* map_access */
+    default_get_sd,             /* get_sd */
+    default_set_sd,             /* set_sd */
+    default_get_full_name,      /* get_full_name */
+    no_lookup_name,             /* lookup_name */
+    directory_link_name,        /* link_name */
+    default_unlink_name,        /* unlink_name */
+    no_open_file,               /* open_file */
+    no_kernel_obj_list,         /* get_kernel_obj_list */
+    no_close_handle,            /* close_handle */
+    inproc_sync_destroy,        /* destroy */
+};
+
 int get_inproc_device_fd(void)
 {
     return -1;
@@ -309,44 +352,97 @@ int get_inproc_device_fd(void)
 
 int get_inproc_sync_fd( struct inproc_sync *sync )
 {
-    return -1;
+    if (!sync) return -1;
+    return sync->fd;
+}
+
+static struct inproc_sync *alloc_msync_inproc_sync( int type, int low, int high )
+{
+    struct inproc_sync *sync;
+
+    if (!(sync = alloc_object( &inproc_sync_ops ))) return NULL;
+    sync->type = type;
+    sync->fd   = msync_alloc_shm( low, high );
+    list_init( &sync->entry );
+    return sync;
 }
 
 struct inproc_sync *create_inproc_internal_sync( int manual, int signaled )
 {
-    return NULL;
+    return alloc_msync_inproc_sync( manual ? MSYNC_MANUAL_SERVER : MSYNC_AUTO_SERVER, signaled, 0 );
 }
 
 struct inproc_sync *create_inproc_event_sync( int manual, int signaled )
 {
-    return NULL;
+    return alloc_msync_inproc_sync( manual ? MSYNC_MANUAL_EVENT : MSYNC_AUTO_EVENT, signaled, 0 );
 }
 
 struct inproc_sync *create_inproc_mutex_sync( thread_id_t owner, unsigned int count )
 {
-    return NULL;
+    struct inproc_sync *mutex = alloc_msync_inproc_sync( MSYNC_MUTEX, owner, count );
+    if (mutex) list_add_tail( &inproc_mutexes, &mutex->entry );
+    return mutex;
 }
 
 struct inproc_sync *create_inproc_semaphore_sync( unsigned int initial, unsigned int max )
 {
-    return NULL;
+    return alloc_msync_inproc_sync( MSYNC_SEMAPHORE, initial, max );
+}
+
+static void inproc_sync_dump( struct object *obj, int verbose )
+{
+    struct inproc_sync *sync = (struct inproc_sync *)obj;
+    assert( obj->ops == &inproc_sync_ops );
+    fprintf( stderr, "Inproc sync (msync) type=%d shm_idx=%d\n", sync->type, sync->fd );
 }
 
 void signal_inproc_sync( struct inproc_sync *sync )
 {
+    msync_signal_all( sync->fd );
 }
 
 void reset_inproc_sync( struct inproc_sync *sync )
 {
+    msync_clear_shm( sync->fd );
+}
+
+static int inproc_sync_signal( struct object *obj, unsigned int access, int signal )
+{
+    struct inproc_sync *sync = (struct inproc_sync *)obj;
+    assert( obj->ops == &inproc_sync_ops );
+    if (signal) signal_inproc_sync( sync );
+    else reset_inproc_sync( sync );
+    return 1;
+}
+
+static void inproc_sync_destroy( struct object *obj )
+{
+    struct inproc_sync *sync = (struct inproc_sync *)obj;
+    assert( obj->ops == &inproc_sync_ops );
+    list_remove( &sync->entry );
+    msync_destroy_semaphore( sync->fd );
 }
 
 void abandon_inproc_mutexes( thread_id_t tid )
 {
+    /* TODO: abandon msync mutexes owned by the dying thread. Mutex abandonment
+     * is also detected client-side on the next acquire, so this is best-effort. */
 }
 
-static int get_obj_inproc_sync( struct object *obj, int *type )
+int get_obj_inproc_sync( struct object *obj, int *type )
 {
-    return -1;
+    struct object *sync;
+    int fd = -1;
+
+    if (!(sync = get_obj_sync( obj ))) return -1;
+    if (sync->ops == &inproc_sync_ops)
+    {
+        struct inproc_sync *inproc = (struct inproc_sync *)sync;
+        *type = inproc->type;
+        fd = inproc->fd;
+    }
+    release_object( sync );
+    return fd;
 }
 
 #endif /* NTSYNC_IOC_EVENT_READ */
@@ -362,6 +458,7 @@ DECL_HANDLER(get_inproc_sync_fd)
 
     if ((fd = get_obj_inproc_sync( obj, &reply->type )) < 0) set_error( STATUS_NOT_IMPLEMENTED );
     else if (do_fsync()) reply->fsync_shm_idx = fsync_grab_shm_idx( fd );
+    else if (do_msync()) reply->fsync_shm_idx = fd; /* macOS: fd is the msync shm index, passed by value (no fd to send) */
     else send_client_fd( current->process, fd, req->handle );
 
     release_object( obj );
