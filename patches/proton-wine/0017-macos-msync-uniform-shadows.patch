@@ -810,13 +800,13 @@ void msync_signal_all( unsigned int shm_idx )
 
 void msync_wake_up( struct object *obj )
 {
-    enum msync_type type;
+    int type, idx;
 
     if (debug_level)
         fprintf( stderr, "msync_wake_up: object %p\n", obj );
 
