@@ -437,9 +421,15 @@ static void *mach_message_pump( void *args )
 int do_msync(void)
 {
 #ifdef __APPLE__
-    /* Always enabled on macOS (matches the client-side do_msync in
-     * dlls/ntdll/unix/msync.c); the wineserver-side fallback is unreliable. */
-    return 1;
+    /* Default on to match the client-side do_msync (dlls/ntdll/unix/msync.c);
+     * WINEMSYNC=0 forces the (unreliable) server fallback for debugging. */
+    static int cached = -1;
+    if (cached == -1)
+    {
+        const char *env = getenv( "WINEMSYNC" );
+        cached = env ? atoi( env ) : 1;
+    }
